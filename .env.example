# ─── Gmail / IMAP credentials (read on the server only) ───────────────────────
# The Gmail address whose inbox is read over IMAP. Also shown to the user in the
# on-screen login instructions.
EMAIL=you@gmail.com

# A Gmail **App Password** (16 chars), NOT your normal account password.
# Create one at https://myaccount.google.com/apppasswords (requires 2FA).
EMAIL_PASSWORD=your_gmail_app_password

# IMAP host. For Gmail this is imap.gmail.com.
IMAP=imap.gmail.com

# ─── Optional overrides ───────────────────────────────────────────────────────
# IMAP_PORT=993
# IMAP_MAILBOX=INBOX
# MAIL_LOOKBACK_DAYS=30
# LOGIN_EMAIL=you@gmail.com   # defaults to EMAIL if unset
