# ─── Gmail / IMAP credentials (read on the server only) ───────────────────────
# The Gmail address whose inbox is read over IMAP. Also shown to the user in the
# on-screen login instructions.
EMAIL=you@gmail.com

# A Gmail **App Password** (16 chars), NOT your normal account password.
# Create one at https://myaccount.google.com/apppasswords (requires 2FA).
EMAIL_PASSWORD=your_gmail_app_password

# IMAP host. For Gmail this is imap.gmail.com.
IMAP=imap.gmail.com

# ─── Visitor notifications via Telegram (optional) ────────────────────────────
# When both are set, opening /claude or /blancvpn sends you a Telegram message
# with the visitor's self-reported handle.
# Bot token: create a bot with @BotFather (/newbot).
# Chat id: your numeric id — write anything to @userinfobot, or open
# https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# ─── Optional overrides ───────────────────────────────────────────────────────
# IMAP_PORT=993
# IMAP_MAILBOX=INBOX
# MAIL_LOOKBACK_DAYS=30
# LOGIN_EMAIL=you@gmail.com   # defaults to EMAIL if unset
